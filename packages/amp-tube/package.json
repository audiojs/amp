{
  "name": "@audio/amp-tube",
  "version": "1.2.3",
  "description": "Tube amp stage — highpass → oversampled tube saturation → bass/mid/treble tone stack → level",
  "type": "module",
  "sideEffects": false,
  "main": "tube.js",
  "exports": {
    ".": "./tube.js",
    "./audio": {
      "types": "./audio.d.ts",
      "default": "./audio.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "tube.js",
    "audio.js",
    "audio.d.ts"
  ],
  "dependencies": {
    "@audio/saturate-tube": "^1.0.0",
    "@audio/biquad": "^1.1.0"
  },
  "keywords": [
    "audio",
    "dsp",
    "amp",
    "guitar",
    "tube"
  ],
  "license": "MIT",
  "author": "Dmitry Iv. <dfcreative@gmail.com>",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "audio": "./audio.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/audiojs/amp.git",
    "directory": "packages/amp-tube"
  }
}
