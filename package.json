{
  "name": "@audio/amp",
  "version": "1.0.1",
  "type": "module",
  "sideEffects": false,
  "description": "Guitar/bass amplification — umbrella for @audio/amp-* atoms (tube stage, cabinet IR)",
  "workspaces": [
    "packages/*"
  ],
  "keywords": [
    "audio",
    "dsp",
    "amp",
    "cabinet",
    "guitar"
  ],
  "license": "MIT",
  "author": "Dmitry Iv. <dfcreative@gmail.com>",
  "engines": {
    "node": ">=18"
  },
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./package.json": "./package.json"
  },
  "files": [
    "index.js"
  ],
  "scripts": {
    "test": "node test.js",
    "test:all": "npm test --workspaces --if-present && npm test",
    "publish:all": "npm publish --workspaces && npm publish"
  },
  "dependencies": {
    "@audio/amp-tube": "^1.0.0",
    "@audio/amp-cabinet": "^1.0.0"
  },
  "devDependencies": {
    "tst": "^9.4.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/audiojs/amp.git"
  }
}
